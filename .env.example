# =============================================================================
# Security Guard Dispatch System — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://guard_user:guard_pass@postgres-db:5432/guard_dispatch_db
POSTGRES_USER=guard_user
POSTGRES_PASSWORD=guard_pass
POSTGRES_DB=guard_dispatch_db

# -----------------------------------------------------------------------------
# Cache (Redis)
# -----------------------------------------------------------------------------
REDIS_CACHE_URL=redis://redis-cache:6379
REDIS_PUBSUB_URL=redis://redis-pubsub:6380

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-64-chars
JWT_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (Push Notifications)
# -----------------------------------------------------------------------------
FCM_SERVER_KEY=<your-firebase-server-key>
FCM_PROJECT_ID=<your-firebase-project-id>

# -----------------------------------------------------------------------------
# Rust Logging
# -----------------------------------------------------------------------------
RUST_LOG=info
RUST_BACKTRACE=1

# -----------------------------------------------------------------------------
# Service Ports (internal)
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=3001
BOOKING_SERVICE_PORT=3002
TRACKING_SERVICE_PORT=3003
NOTIFICATION_SERVICE_PORT=3004
MEDIASOUP_PORT=3005
CHAT_SERVICE_PORT=3006

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# MediaSoup (Node.js)
# -----------------------------------------------------------------------------
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
NODE_ENV=development

# -----------------------------------------------------------------------------
# MinIO / S3 Object Storage
# Development: MinIO (self-hosted Docker)
# Production:  Cloudflare R2 (change S3_ENDPOINT to R2 endpoint)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=guard-dispatch-files
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  ← Production R2
# S3_ACCESS_KEY=<r2-access-key>
# S3_SECRET_KEY=<r2-secret-key>
