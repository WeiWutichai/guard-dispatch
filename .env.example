# =============================================================================
# Security Guard Dispatch System — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://guard_user:guard_pass@postgres-db:5432/guard_dispatch_db
POSTGRES_USER=guard_user
POSTGRES_PASSWORD=guard_pass
POSTGRES_DB=guard_dispatch_db

# -----------------------------------------------------------------------------
# Cache (Redis) — password-protected
# -----------------------------------------------------------------------------
REDIS_PASSWORD=redis_secret_pass
REDIS_CACHE_URL=redis://:redis_secret_pass@redis-cache:6379
REDIS_PUBSUB_URL=redis://:redis_secret_pass@redis-pubsub:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-64-chars
JWT_EXPIRY_HOURS=24

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (Push Notifications)
# -----------------------------------------------------------------------------
FCM_SERVER_KEY=<your-firebase-server-key>
FCM_PROJECT_ID=<your-firebase-project-id>

# -----------------------------------------------------------------------------
# Rust Logging
# -----------------------------------------------------------------------------
RUST_LOG=info
RUST_BACKTRACE=1

# -----------------------------------------------------------------------------
# Service Ports (internal — no longer exposed to host, only via Nginx)
# These are kept for reference only; services use fixed internal ports.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Nginx
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# MediaSoup (Node.js)
# -----------------------------------------------------------------------------
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
NODE_ENV=development

# -----------------------------------------------------------------------------
# MinIO / S3 Object Storage
# Development: MinIO (self-hosted Docker)
# Production:  Cloudflare R2 (change S3_ENDPOINT to R2 endpoint)
# -----------------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=guard-dispatch-s3-access
S3_SECRET_KEY=change-me-to-a-strong-s3-secret-key
S3_BUCKET=guard-dispatch-files
# Public URL rewrite for presigned URLs (used by browsers to load document images).
# Nginx proxies /minio-files/ → minio:9000 with Host: minio:9000.
# Production (R2): omit this var — S3_ENDPOINT is already a public URL.
S3_PUBLIC_URL=http://localhost/minio-files
CORS_ALLOWED_ORIGINS=http://localhost:3000
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com  ← Production R2
# S3_ACCESS_KEY=<r2-access-key>
# S3_SECRET_KEY=<r2-secret-key>

# -----------------------------------------------------------------------------
# INET SMS Gateway (Cheese Digital Network CSGAPI)
# Used for sending OTP via SMS during registration
# API doc: https://bulksms.cheesemobile.com/v2/
# -----------------------------------------------------------------------------
INET_SMS_USERNAME=<your-inet-username>
INET_SMS_PASSWORD=<your-inet-password>
INET_SMS_SENDER=GuardApp
INET_SMS_URL=https://bulksms.cheesemobile.com/v2/

# -----------------------------------------------------------------------------
# OTP Settings
# -----------------------------------------------------------------------------
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6
OTP_RATE_LIMIT_SECONDS=60
PHONE_VERIFY_TTL_MINUTES=10
DAILY_OTP_LIMIT=10
